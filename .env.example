# Copie para .env e preencha com suas chaves.
# (O .env real é ignorado pelo git — veja .gitignore.)

# TheSportsDB — "3" é a chave pública de teste (limites baixos).
VITE_TSDB_KEY=3

# Google Gemini — gere em https://aistudio.google.com/apikey
VITE_GEMINI_KEY=

# ── Códigos de aposta da Betano (Bilhetes do dia) ──
# Definir na Vercel (Project Settings → Environment Variables), NÃO no cliente.
#
# ADMIN_SECRET: senha do painel #admin (você inventa). Sem ela, não dá pra salvar códigos.
ADMIN_SECRET=
# KV_REST_API_URL / KV_REST_API_TOKEN são injetadas automaticamente ao instalar
# a integração "Upstash for Redis" no Marketplace da Vercel — não precisa preencher à mão.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
